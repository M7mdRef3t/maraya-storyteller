# =============================================================================
# Maraya Storyteller - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Required: Your Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional: Gemini model for text generation (default shown)
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Optional: Imagen model for image generation (default shown)
IMAGEN_MODEL=imagen-3.0-generate-002

# Optional: Gemini image-capable model fallback if Imagen model is unavailable
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: Server port (default: 8080)
PORT=8080

# Optional: Logging level (info | debug)
LOG_LEVEL=info

# Optional: Enable PAEF/Firestore integration (default: enabled)
# In local development, PAEF now auto-disables unless one of these is set:
# - GOOGLE_APPLICATION_CREDENTIALS
# - FIRESTORE_EMULATOR_HOST
# To force-disable it manually, set ENABLE_PAEF=false
ENABLE_PAEF=true

# Optional: Local GCP ADC credential file for Firestore-backed PAEF
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: Firestore emulator host for local PAEF development
# Example: localhost:8081
FIRESTORE_EMULATOR_HOST=
